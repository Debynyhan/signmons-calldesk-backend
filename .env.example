NODE_ENV=development
AI_PROVIDER=openai
PORT=3000
DATABASE_URL=postgresql://USER:PASSWORD@localhost:5432/postgres?schema=public
FRONTEND_ORIGINS=http://localhost:3000,http://localhost:3101
ENABLED_TOOLS=create_job
DEV_AUTH_ENABLED=false
DEV_AUTH_SECRET=dev-auth-secret

# OpenAI (current provider)
OPENAI_API_KEY=
ENABLE_GPT5_1_CODEX=false

# Vertex AI (planned)
VERTEX_AI_PROJECT_ID=
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_MODEL=gemini-1.5-pro

# Google Cloud platform
GOOGLE_CLOUD_PROJECT=signmons
GOOGLE_APPLICATION_CREDENTIALS="$HOME/.config/signmons/service-account.json"
CLOUD_SQL_CONNECTION_NAME=signmons:us-east5:signmons-db
CLOUD_TASKS_QUEUE=
CLOUD_TASKS_LOCATION=

# Identity Platform
IDENTITY_PLATFORM_PROJECT_ID=
IDENTITY_PLATFORM_WEB_API_KEY=
IDENTITY_PLATFORM_ISSUER=

# Address Validation
GOOGLE_MAPS_API_KEY=

# Stripe Connect
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# PostHog
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# Testing
RUN_E2E=false
TEST_DATABASE_URL=
