NODE_ENV=development
AI_PROVIDER=openai
PORT=3000
DATABASE_URL=postgresql://calldesk:call_backend_v1@localhost:5432/calldesk?schema=public
FRONTEND_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3101
ENABLED_TOOLS=route_conversation,create_job
ADMIN_API_TOKEN=dev-admin-token
AI_MAX_TOKENS=800
AI_MAX_TOOL_CALLS=1
AI_TIMEOUT_MS=15000
AI_MAX_RETRIES=1
AI_VOICE_REPLY_TEMPERATURE=0.6
AI_EXTRACTION_TEMPERATURE=0.1

# OpenAI (current provider)
OPENAI_API_KEY=your-openai-api-key
ENABLE_GPT5_1_CODEX=false
AI_DEFAULT_MODEL=gpt-4o-mini
AI_PREVIEW_MODEL=gpt-5.1-codex
AI_TEXT_MODEL=
AI_VOICE_MODEL=
AI_ROUTER_MODEL=
AI_BOOKING_MODEL=
AI_FAQ_MODEL=
AI_EXTRACTION_MODEL=
AI_ROUTER_FLOW_ENABLED=true
AI_ROUTER_FLOW_SMS_ENABLED=true
AI_ROUTER_FLOW_WEBCHAT_ENABLED=true
AI_ROUTER_FLOW_ALLOWLIST_ONLY=false
AI_ROUTER_FLOW_TENANT_ALLOWLIST=

# Vertex AI (planned)
VERTEX_AI_PROJECT_ID=
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_MODEL=gemini-1.5-pro

# Google Cloud platform
GOOGLE_CLOUD_PROJECT=signmons
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
CLOUD_SQL_CONNECTION_NAME=
CLOUD_TASKS_QUEUE=
CLOUD_TASKS_LOCATION=
GOOGLE_SPEECH_ENABLED=false
GOOGLE_SPEECH_LANGUAGE_CODE=en-US
GOOGLE_SPEECH_MODEL=phone_call
GOOGLE_SPEECH_USE_ENHANCED=true
GOOGLE_SPEECH_ENCODING=MULAW
GOOGLE_SPEECH_SAMPLE_RATE_HZ=8000
GOOGLE_SPEECH_INTERIM_RESULTS=true
GOOGLE_TTS_ENABLED=false
GOOGLE_TTS_LANGUAGE_CODE=en-US
GOOGLE_TTS_VOICE_NAME=en-US-Studio-O
GOOGLE_TTS_AUDIO_ENCODING=MP3
GOOGLE_TTS_SPEAKING_RATE=1.0
GOOGLE_TTS_PITCH=0
GOOGLE_TTS_VOLUME_GAIN_DB=0
GOOGLE_TTS_BUCKET=signmons-bucket-1
GOOGLE_TTS_SIGNED_URL_TTL_SEC=900

# Dev Auth (Development only)
DEV_AUTH_ENABLED=true
DEV_AUTH_SECRET=dev-auth-secret

# Identity Platform / Firebase
IDENTITY_ISSUER=https://securetoken.google.com/signmons
IDENTITY_AUDIENCE=signmons
FIREBASE_PROJECT_ID=signmons

# Address Validation
GOOGLE_MAPS_API_KEY=

# Stripe Connect
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# WARNING: only for local debugging. NEVER set true in CI, staging, or production.
# Recommended local flow: use `stripe listen --forward-to localhost:3000/...` instead.
STRIPE_WEBHOOK_ALLOW_INSECURE_LOCAL=false
STRIPE_CONNECT_CLIENT_ID=
SMS_INTAKE_LINK_SECRET=
SMS_INTAKE_LINK_TTL_MINUTES=1440
SMS_INTAKE_BASE_URL=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
VOICE_ENABLED=false
TWILIO_SIGNATURE_CHECK=true
TWILIO_WEBHOOK_BASE_URL=
DEMO_TENANT_ID=
VOICE_MAX_TURNS=6
VOICE_MAX_DURATION_SEC=180
VOICE_ADDRESS_MIN_CONFIDENCE=0.7
VOICE_SOFT_CONFIRM_MIN_CONFIDENCE=0.85
VOICE_STREAMING_ENABLED=false
VOICE_STREAMING_KEEPALIVE_SEC=60
VOICE_STREAMING_TRACK=inbound
# Optional provider override. Leave blank for backward-compatible auto mode:
# - auto -> google when GOOGLE_SPEECH_ENABLED/GOOGLE_TTS_ENABLED is true, otherwise twilio.
VOICE_STT_PROVIDER=
VOICE_TTS_PROVIDER=
# Optional: number of characters that should use Twilio <Say> instead of Google TTS.
# Set 0 to keep a consistent Google voice for all prompts.
VOICE_TTS_SHORT_SAY_MAX_CHARS=0
ADDRESS_VALIDATION_PROVIDER=none
GOOGLE_PLACES_API_KEY=

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# PostHog
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# Testing
RUN_E2E=false
TEST_DATABASE_URL=postgresql://calldesk:calldesk_backend_v1@localhost:5432/calldesk?schema=calldesk_test
