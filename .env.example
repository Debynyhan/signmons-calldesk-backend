NODE_ENV=development
AI_PROVIDER=openai
PORT=3000
DATABASE_URL=postgresql://calldesk:call_backend_v1@localhost:5432/calldesk?schema=public
FRONTEND_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:3101
ENABLED_TOOLS=create_job
ADMIN_API_TOKEN=dev-admin-token
AI_MAX_TOKENS=800
AI_MAX_TOOL_CALLS=1
AI_TIMEOUT_MS=15000
AI_MAX_RETRIES=1
AI_VOICE_REPLY_TEMPERATURE=0.6
AI_EXTRACTION_TEMPERATURE=0.1

# OpenAI (current provider)
OPENAI_API_KEY=your-openai-api-key
ENABLE_GPT5_1_CODEX=false

# Vertex AI (planned)
VERTEX_AI_PROJECT_ID=
VERTEX_AI_LOCATION=us-central1
VERTEX_AI_MODEL=gemini-1.5-pro

# Google Cloud platform
GOOGLE_CLOUD_PROJECT=signmons
GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
CLOUD_SQL_CONNECTION_NAME=
CLOUD_TASKS_QUEUE=
CLOUD_TASKS_LOCATION=

# Dev Auth (Development only)
DEV_AUTH_ENABLED=true
DEV_AUTH_SECRET=dev-auth-secret

# Identity Platform / Firebase
IDENTITY_ISSUER=https://securetoken.google.com/signmons
IDENTITY_AUDIENCE=signmons
FIREBASE_PROJECT_ID=signmons

# Address Validation
GOOGLE_MAPS_API_KEY=

# Stripe Connect
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_CONNECT_CLIENT_ID=

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
VOICE_ENABLED=false
TWILIO_SIGNATURE_CHECK=true
TWILIO_WEBHOOK_BASE_URL=
DEMO_TENANT_ID=
VOICE_MAX_TURNS=6
VOICE_MAX_DURATION_SEC=180
VOICE_ADDRESS_MIN_CONFIDENCE=0.7
VOICE_SOFT_CONFIRM_MIN_CONFIDENCE=0.85
ADDRESS_VALIDATION_PROVIDER=none
GOOGLE_PLACES_API_KEY=

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# Sentry
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.1

# PostHog
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# Testing
RUN_E2E=false
TEST_DATABASE_URL=postgresql://calldesk:calldesk_backend_v1@localhost:5432/calldesk?schema=calldesk_test
